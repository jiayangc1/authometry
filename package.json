{
  "name": "authometry",
  "version": "0.1.0",
  "private": true,
  "description": "Transparent, Git-native OAuth 2.0 and OpenID Connect infrastructure.",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "concurrently -n api,web -c blue,magenta \"pnpm --filter @authometry/server dev\" \"pnpm --filter @authometry/web dev\"",
    "dev:api": "pnpm --filter @authometry/server dev",
    "dev:web": "pnpm --filter @authometry/web dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "conformance": "tsx scripts/conformance-smoke.ts",
    "typecheck": "pnpm -r --if-present typecheck && tsc -p tests/tsconfig.json",
    "db:migrate": "pnpm --filter @authometry/server migrate"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.10",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.1.10"
  }
}
