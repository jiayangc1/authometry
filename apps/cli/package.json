{
  "name": "authometry",
  "version": "0.1.2",
  "description": "Configuration-as-code CLI for Authometry.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jiayangc1/authometry.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/jiayangc1/authometry#readme",
  "bugs": "https://github.com/jiayangc1/authometry/issues",
